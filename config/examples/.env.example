# Copy this file to config/local/.env and fill in local-only values.
# The default public bootstrap uses noop transport, so you can leave most of
# these blank until you enable a provider, market adapter, or chat transport.

# Tushare (A-stock data)
TUSHARE_TOKEN=

# Yahoo Finance needs no key

# Polymarket
POLYMARKET_API_URL=https://gamma-api.polymarket.com

# LLM provider
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
