{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NormalizedFact",
  "type": "object",
  "required": [
    "fact_id", "fact", "company", "tickers", "topic", "as_of", "date",
    "source_ref", "source_type", "confidence", "decay_class", "tags", "status"
  ],
  "properties": {
    "fact_id": {"type": "string", "pattern": "^f_\\d{8}_\\d{3}$"},
    "fact": {"type": "string", "minLength": 1},
    "company": {"type": "array", "items": {"type": "string"}},
    "tickers": {"type": "array", "items": {"type": "string"}},
    "topic": {"type": "string"},
    "as_of": {"type": "string", "format": "date"},
    "date": {"type": "string", "format": "date"},
    "source_ref": {"type": "string"},
    "source_type": {
      "type": "string",
      "enum": ["company_research", "personal_note", "industry_data", "expert_minutes", "sell_side", "media_news", "social_rumor"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "decay_class": {
      "type": "string",
      "enum": ["ephemeral", "periodic", "structural", "financial"]
    },
    "tags": {"type": "array", "items": {"type": "string"}},
    "status": {
      "type": "string",
      "enum": ["active", "superseded", "disputed", "revision", "pending_conflict"]
    },
    "supersedes": {"type": ["string", "null"]},
    "supersede_type": {"type": ["string", "null"]}
  }
}
